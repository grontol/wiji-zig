import "std"

enum Dir {
    left,
    right,
    up,
    down,
    
    fn print(self: @Self) {
        switch self @partial {
            .up, .down @fallthrough => printf("Up or Down\n"),
            .left  => {
                printf("Left\n")
            },
        }
    }
}

fn main() {
    Dir.right.print()
    
    const s = "ASCII (American Standard Code for Information Interchange) is a 7-bit character"
    
    for ch in s {
        printf("%c => ", ch)
        
        switch ch {
            '0'...'9' => printf("Digit\n"),
            'a'...'z' => printf("Alphabet\n"),
            ' ', '\n' => printf("Space\n"),
            else => printf("Symbol\n")
        }
    }
}

