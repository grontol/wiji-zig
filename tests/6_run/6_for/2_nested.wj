fn main() {
    val y = 7

    if y < 10 {
        print("< 10\n")

        for a in 0..y {
            print("{} -> ", a)

            if a % 2 == 0 print("Genap\n")
            else print("Ganjil\n")

            for b in a {
                print("{}\n", b + 1)
                
                for c in b {
                    if c % 2 == 0 print ("  xxx ")
                    else print("  ")
                    
                    print("  {}\n", c + 1)
                }
            }
        }

        if false {
            print("True\n")
        }
        else {
            print("False\n")
        }
    }
    else if y > 10 {
        print("> 10\n")
    }
    else {
        print("= 10\n")

        for a in y..y + 3 {
            print("{}\n", a * 10)
        }
    }

    val x = 3
    val z = 3

    if x < 4 {
        print("x < 4\n")

        if z < 4 print("1 y < 4\n")
        else if z > 4 print("1 y > 4\n")
        else print("1 y == 4\n")
    }
    else if x > 4 {
        print("x > 4\n")

        if z < 4 print("2 y < 4\n")
        else if z > 4 print("2 y > 4\n")
        else print("2 y == 4\n")
    }
    else {
        print("x == 4\n")

        if z < 4 print("3 y < 4\n")
        else if z > 4 print("3 y > 4\n")
        else print("3 y == 4\n")
    }
    
    print("\n-----------------------\n")
    
    for a in 10 {
        for a + 1 print("*")
        
        print("\n")
    }
    
    print("-----------------------\n")

    print("Done\n")
}

@builtin fn print(fmt: string, ...values: any)

