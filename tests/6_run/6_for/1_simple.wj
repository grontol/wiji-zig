fn main() {
    val x = 3
    
    for a in 0..x {
        print("{}\n", a)
    }
    
    print("\n")
    for a in 0..x print("{}\n", a)
    print("\n")
    for a in x print("{}\n", a)
    print("\n")
    for x print("x\n")
    print("\n")
    for 3 print("?\n")
//    for 10 print("x\n")
}

@builtin fn print(fmt: string, ...values: any)

