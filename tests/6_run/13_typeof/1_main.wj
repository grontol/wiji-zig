struct Foo {
    x = 10
    
    fn foo() {}
    fn bar(self: &Foo) {}
    fn baz(self: Foo, v: i32) {}
}

enum Human {
    boy,
    girl,
    
    fn foo() {}
    fn bar(self: Human) {}
    fn baz(self: Human, v: i32) {}
}

fn main() {
    const x = 1
    const y = 2.0
    const foo = Foo.{}
    const human = Human.boy
    const str = "STRING"
    const chr = 'c'
    
    print("@typeOf(1) = {}\n", @typeOf(1))
    print("@typeOf(2.3) = {}\n", @typeOf(2.3))
    print("@typeOf(x) = {}\n", @typeOf(x))
    print("@typeOf(y) = {}\n", @typeOf(y))
    print("@typeOf(foo) = {}\n", @typeOf(foo))
    print("@typeOf(str) = {}\n", @typeOf(str))
    print("@typeOf(chr) = {}\n", @typeOf(chr))
    print("@typeOf(Foo) = {}\n", @typeOf(Foo))
    print("@typeOf(Foo.foo) = {}\n", @typeOf(Foo.foo))
    print("@typeOf(Foo.bar) = {}\n", @typeOf(Foo.bar))
    print("@typeOf(Foo.baz) = {}\n", @typeOf(Foo.baz))
    print("@typeOf(foo.x) = {}\n", @typeOf(foo.x))
    print("@typeOf(human) = {}\n", @typeOf(human))
    print("@typeOf(Human) = {}\n", @typeOf(Human))
    print("@typeOf(Human.foo) = {}\n", @typeOf(Human.foo))
    print("@typeOf(Human.bar) = {}\n", @typeOf(Human.bar))
    print("@typeOf(Human.baz) = {}\n", @typeOf(Human.baz))
    print("@typeOf(print) = {}\n", @typeOf(print))
}

@builtin fn print(fmt: string, ...args: any)

/***
@typeOf(1) = int
@typeOf(2.3) = float
@typeOf(x) = i32
@typeOf(y) = f32
@typeOf(foo) = Foo
@typeOf(str) = string
@typeOf(chr) = u8
@typeOf(Foo) = type(struct:Foo)
@typeOf(Foo.foo) = fn(): void
@typeOf(Foo.bar) = fn(&Foo): void
@typeOf(Foo.baz) = fn(Foo, i32): void
@typeOf(foo.x) = i32
@typeOf(human) = Human
@typeOf(Human) = type(enum:Human)
@typeOf(Human.foo) = fn(): void
@typeOf(Human.bar) = fn(Human): void
@typeOf(Human.baz) = fn(Human, i32): void
@typeOf(print) = fn(string, ...any): void
***/