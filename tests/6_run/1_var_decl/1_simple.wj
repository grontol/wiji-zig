fn main() {
    val a = 10
    val b = 'x'
    val c = "Satu dia"
    val d = true
    val e = false
    
    val f = a == 0
    val g = a < 0
    val h = a <= 0
    val i = a > 0
    val j = a >= 0
    val k = a == 0
    val l = a != 0
    
    print("a = {}\n", a)
    print("b = {:c}\n", b)
    print("c = {}\n", c)
    print("d = {}\n", d)
    print("e = {}\n", e)
    
    print("f = {}\n", f)
    print("g = {}\n", g)
    print("h = {}\n", h)
    print("i = {}\n", i)
    print("j = {}\n", j)
    print("k = {}\n", k)
    print("l = {}\n", l)
}

@builtin fn print(fmt: string, ...values: any)

