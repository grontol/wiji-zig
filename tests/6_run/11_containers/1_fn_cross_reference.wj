struct Foo {
    x: i32
    
    fn foo() {
        Bar.foo()
        print("Foo foo\n")
    }
    
    fn bar() {
        print("Foo bar\n")
    }
}

struct Bar {
    fn foo() {
        print("Bar foo\n")
    }
    
    fn bar() {
        Foo.bar()
        print("Bar bar\n")
        
        E1.foo()
    }
}

enum E1 {
    fn foo() {
        print("E1 foo\n")
        E2.foo()
    }
}

enum E2 {
    fn foo() {
        print("E2 foo\n")
        Foo.foo()
        Foo.bar()
    }
}

fn main() {
    Foo.foo()
    Bar.bar()
    
    E1.foo()
}

@builtin fn print(fmt: string, ...args: any)

/***
Bar foo
Foo foo
Foo bar
Bar bar
E1 foo
E2 foo
Bar foo
Foo foo
Foo bar
E1 foo
E2 foo
Bar foo
Foo foo
Foo bar
***/