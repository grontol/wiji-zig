struct Foo {
    x: i32
    
    fn foo() {
        Bar.foo()
        printf("Foo foo\n")
    }
    
    fn bar() {
        printf("Foo bar\n")
    }
}

struct Bar {
    fn foo() {
        printf("Bar foo\n")
    }
    
    fn bar() {
        Foo.bar()
        printf("Bar bar\n")
        
        E1.foo()
    }
}

enum E1 {
    fn foo() {
        printf("E1 foo\n")
        E2.foo()
    }
}

enum E2 {
    fn foo() {
        printf("E2 foo\n")
        Foo.foo()
        Foo.bar()
    }
}

fn main() {
    Foo.foo()
    Bar.bar()
    
    E1.foo()
}

extern fn printf(fmt: string, ...args: any)

/***
