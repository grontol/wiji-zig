struct Foo {
    x: i32
    
    fn foo(self: @Self) {
        printf("x = %d\n", self.x)
    }
}

enum Kind {
    one,
    two,
    
    fn print(self: @Self) {
        if self == .one {
            printf("is one\n")
        }
        else {
            printf("is two\n")
        }
    }
}

fn main() {
    const f = Foo.{10}
    f.foo()
    
    var k = Kind.one
    k.print()
    
    k = .two
    k.print()
}

extern fn printf(fmt: string, ...args: any)

/***
x = 10
is one
is two
***/