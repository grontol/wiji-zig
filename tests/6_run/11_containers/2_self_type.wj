struct Foo {
    x: i32
    
    fn foo(self: @Self) {
        print("x = {}\n", self.x)
    }
}

enum Kind {
    one,
    two,
    
    fn prints(self: @Self) {
        if self == .one {
            print("is one\n")
        }
        else {
            print("is two\n")
        }
    }
}

fn main() {
    const f = Foo.{10}
    f.foo()
    
    var k = Kind.one
    k.prints()
    
    k = .two
    k.prints()
}

@builtin fn print(fmt: string, ...args: any)

/***
x = 10
is one
is two
***/