fn main() {
    const t = 3

    {
        var a = 0
        while a < t {
            print("{}\n", a)
            a += 1
        }
    }
    
    print("\n")
    
    {
        var a = t
        while a > 0 {
            print("{}\n", a)
            a -= 1
        }
    }
    
    print("\n")

    {
        var a = 0
        while a < t * 2 {
            print("{}\n", a)
            a += 2
        }
    }
    
    print("\n")
    
    {
        var a = t * 2
        while a > 0 {
            print("{}\n", a)
            a -= 2
        }
    }
}

@builtin fn print(fmt: string, ...values: any)

