fn main() {
    var a = 0

    while a < 5 {
        print("{} -> ", a)
        
        if a % 2 == 0 print("Even\n")
        else print("Odd\n")
        
        var c = 0
        
        while c <= a {
            print("x")
            c += 1
        }
        
        print("\n")
        
        a += 1
    }
}

@builtin fn print(fmt: string, ...values: any)

/***
0 -> Even
x
1 -> Odd
xx
2 -> Even
xxx
3 -> Odd
xxxx
4 -> Even
xxxxx
***/