import "std"

fn main() {
    const input = .[1, 3, 10, 20, 30, 2, 2, 5, 6, 3, 3, 7, 7, 7]
    var ip = 0
    var output: [dyn]i32 = .[]
    
    while ip + 1 < input.len {
        const type = input[ip]
        const len = input[ip + 1]
        
        if ip + 1 + len >= input.len {
            print("INVALID PACKET\n")
            return
        }
        
        const payloadIndex = ip + 2
        
        switch type {
            1 => {
                for i in payloadIndex..payloadIndex + len {
                    output.append(input[i])
                }
            },
            2 => {
                for i in payloadIndex..payloadIndex + len @reversed {
                    output.append(input[i])
                }
            },
            else => {
                var res = 0
                
                for i in payloadIndex..payloadIndex + len {
                    res ^= input[i]
                }
                
                output.append(res)
            }
        }
        
        ip += 2 + len
    }
    
    printArray(output)
}

fn printArray<T>(arr: [dyn]T) {
    print("[")
    
    for i in arr.len {
        if i > 0 {
            print(", ")
        }
        
        print("{}", arr[i])
    }
    
    print("]\n")
}

/***
[10, 20, 30, 6, 5, 7]
***/