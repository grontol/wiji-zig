struct Foo {
    const X = Bar.Y
    const Y = 50 + Z
    const Z = 40
}

enum Bar {
    const X = Foo.Y
    const Y = 20 + Z
    const Z = 10
}

fn main() {
    print("Foo.X = {}\n", Foo.X)
    print("Bar.X = {}\n", Bar.X)
}

@builtin fn print(fmt: string, ...args: any)

/***
Foo.X = 30
Bar.X = 90
***/