const FOO = .[1] ** 10
const BAR = .[1, 2, 3] ** 3
const BAZ = .[0, 1] ++ .[2, 3]

fn main() {
    for f in FOO {
        print("{}\n", f)
    }
    
    for b in BAR {
        print("{}\n", b)
    }
    
    for b in BAZ {
        print("{}\n", b)
    }
}

@builtin fn print(fmt: string, ...args: any)

