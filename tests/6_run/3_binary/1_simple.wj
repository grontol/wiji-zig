fn main() {
    print("{}\n", 10 + 2)
    print("{}\n", 10 + 2 * 3)
    print("{}\n", 10 + 2 * 3 + 13 / 3)
    print("{}\n", 10 + 2 * (3 + 13) / 3)
    print("{}\n", (10 + 2) * (3 + 13) / 3)
    print("{}\n", 12 * (23 + 4 * (45 + 5) + 34) - 54 + 34 * 3 / 45)
    print("{}\n", 12 * (23 + 4 * (45 - 5) + 34) % 4 * 34 + 45 * 4 % 2 + 54 + 34 * 3 / 45)
    print("{}\n", 12 * (23 + 4 * (45 - 5) + 34) % 4 > 34 + 45 * 4 % 2 + 54 + 34 * 3 / 45)
    print("{}\n", 12 * (23 + 4 * (45 - 5) + 34) % 4 * 34 < 45 * 4 % 2 + 54 + 34 * 3 / 45)
    print("{}\n", 12 * (23 + 4 * (45 - 5) + 34) == 4 * 34 + 45 * 4 % 2 + 54 + 34 * 3 / 45)
    print("{}\n", 12 <= (23 + 4 * (45 - 5) + 34) % 4 * 34 + 45 * 4 % 2 + 54 + 34 * 3 / 45)
    print("{}\n", 12 >= (23 + 4 * (45 - 5) + 34) % 4 * 34 + 45 * 4 % 2 + 54 + 34 * 3 / 45)
}

@builtin fn print(fmt: string, ...values: any)

