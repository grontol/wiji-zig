struct Point {
    var times = 3
    
    x: i32
    y: i32
    z = 30
    
    const INC = 10
    
    fn incAndPrint(self: &Point) {
        self.x += INC
        self.y += INC
        self.z += INC
        
        self.print()
    }
    
    fn timesAndPrint(self: &Point) {
        self.x *= times
        self.y *= times
        self.z *= times
        
        self.print()
        
        times += 1
    }
    
    fn print(self: Point) {
        printf("x = %d, y = %d, z = %d\n", self.x, self.y, self.z)
    }
}

fn main() {
    val p = Point.{10, 20}
    p.incAndPrint()
    p.timesAndPrint()
    p.timesAndPrint()
    p.timesAndPrint()
}

extern fn printf(fmt: string, ...args: any)

