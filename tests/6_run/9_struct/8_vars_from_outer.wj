struct Point {
    var times = 3
    
    x: i32
    y: i32
    z = 30
    
    const INC = 10
    
    fn prints(self: Point) {
        print("x = {}, y = {}, z = {}\n", self.x, self.y, self.z)
    }
}

fn main() {
    val p = Point.{10, 20}
    
    p.x *= Point.times
    p.y *= Point.times
    p.z *= Point.times
    p.prints()
    
    Point.times += 1
    p.x *= Point.times
    p.y *= Point.times
    p.z *= Point.times
    p.prints()
    
    p.x += Point.INC
    p.y += Point.INC
    p.z += Point.INC
    p.prints()
}

@builtin fn print(fmt: string, ...args: any)

/***
x = 30, y = 60, z = 90
x = 120, y = 240, z = 360
x = 130, y = 250, z = 370
***/