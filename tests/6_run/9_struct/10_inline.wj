struct Foo {
    x: i32
    using bar: struct {
        y: i32
        z: i32
        
        fn barz(self: @Self) {
            print("y = {}, z = {}\n", self.y, self.z)
        }
    }
}

fn main() {
    const f = Foo.{
        x = 10,
        bar = .{10, 20}
    }
    
    f.barz()
}

@builtin fn print(fmt: string, ...args: any)

/***
y = 10, z = 20
***/