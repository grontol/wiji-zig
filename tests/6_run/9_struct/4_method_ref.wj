struct Point {
    x: i32
    y: i32
    z = 30
    
    fn inc(self: &Point) {
        self.x += 1
        self.y += 1
        self.z += 1
    }
    
    fn prints(self: Point) {
        print("x = {}, y = {}, z = {}\n", self.x, self.y, self.z)
    }
}

fn main() {
    val p = Point.{10, 20}
    p.inc()
    p.prints()
}

@builtin fn print(fmt: string, ...args: any)

/***
x = 11, y = 21, z = 31
***/