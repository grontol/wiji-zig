fn main() {
    {
        val a = 10
        val b = 20
        val c = 4

        if a > 5 {
            if b < 10 {
                print("If if\n")
                if c > 3 print("1 c > 3\n")
            }
            else {
                print("If else\n")
                if c > 3 print("2 c > 3\n") 
            }

            print("If end\n")
        }
        else {
            print("Else\n")
        }
    }
    
    print("\n")
    
    {
        val a = 10
        val b = 2
        val c = 4

        if a > 5 {
            if b < 10 {
                print("If if\n")
                if c > 3 print("1 c > 3\n")
            }
            else {
                print("If else\n")
                if c > 3 print("2 c > 3\n") 
            }

            print("If end\n")
        }
        else {
            print("Else\n")
        }
    }

    print("\n")

    {
        val a = 10
        val b = 2
        val c = 1

        if a > 5 {
            if b < 10 {
                print("If if\n")
                if c > 3 print("1 c > 3\n")
            }
            else {
                print("If else\n")
                if c > 3 print("2 c > 3\n") 
            }

            print("If end\n")
        }
        else {
            print("Else\n")
        }
    }

    print("\n")

    {
        val a = 1
        val b = 2
        val c = 1

        if a > 5 {
            if b < 10 {
                print("If if\n")
                if c > 3 print("1 c > 3\n")
            }
            else {
                print("If else\n")
                if c > 3 print("2 c > 3\n") 
            }

            print("If end\n")
        }
        else {
            print("Else\n")
        }
    }
}

@builtin fn print(fmt: string, ...value: any)

