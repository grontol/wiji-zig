enum Kind {
    var PREFIX = "YOYOYO => "
    
    player,
    enemy,
    
    fn prints(self: Kind, name: string) {
        if self == .player {
            print("{}{} is player\n", PREFIX, name)
        }
        else if self == .enemy {
            print("{}{} is enemy\n", PREFIX, name)
        }
    }
}

fn main() {
    const p = Kind.player
    const e: Kind = .enemy
    
    p.prints("p")
    e.prints("e")
    
    Kind.PREFIX = "====> "
    
    p.prints("p")
    e.prints("e")
}

@builtin fn print(fmt: string, ...args: any)

/***
YOYOYO => p is player
YOYOYO => e is enemy
====> p is player
====> e is enemy
***/