struct Foo {
    x: i32
    kind: enum {
        one,
        two,
        
        fn foo(self: @Self) {
            if self == .one {
                print("is one\n")
            }
            else {
                print("is two\n")
            }
        }
    }
}

fn main() {
    const f = Foo.{
        x = 10,
        kind = .two,
    }
    
    f.kind.foo()
}

@builtin fn print(fmt: string, ...args: any)

/***
is two
***/