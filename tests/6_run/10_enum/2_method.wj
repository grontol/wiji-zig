enum Kind {
    player,
    enemy,
    
    fn prints(self: Kind, name: string) {
        if self == .player {
            print("{} is player\n", name)
        }
        else if self == .enemy {
            print("{} is enemy\n", name)
        }
    }
}

fn main() {
    const p = Kind.player
    const e: Kind = .enemy
    
    p.prints("p")
    e.prints("e")
}

@builtin fn print(fmt: string, ...args: any)

/***
p is player
e is enemy
***/