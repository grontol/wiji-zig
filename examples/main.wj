import "std"

@builtin fn print(x: string, ...args: any)

struct Inner {
    a: i32
    b: i32
}

struct Point {
    x: i32
    y: i32
    i: Inner
}

fn main() {
    const x = "SSSS"
    const c = 'x'
    const p = Point.{10, 20, .{1, 2}}
    
    print("Foo bar {} {} {:c}\n", 10, x, c)
    print("{:$}\n", p)
}